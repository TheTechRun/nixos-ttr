{
  "name": "markdown-code-copy",
  "displayName": "Markdown Code Copy",
  "description": "Adds copy buttons to code blocks in markdown preview",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/classerton/nixos-config"
  },
  "author": "ttr",
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "markdown.previewStyles": [
      "./media/preview.css"
    ],
    "markdown.previewScripts": [
      "./media/preview.js"
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  }
}